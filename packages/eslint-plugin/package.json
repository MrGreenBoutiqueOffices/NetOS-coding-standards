{
  "name": "@net-os/eslint-plugin",
  "version": "0.0.4",
  "description": "Official ESLint plugin for NetOS, enforcing consistent coding standards across frontend projects.",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "lint",
    "linter"
  ],
  "homepage": "https://github.com/MrGreenBoutiqueOffices/NetOS-coding-standards#readme",
  "bugs": {
    "url": "https://github.com/MrGreenBoutiqueOffices/NetOS-coding-standards/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MrGreenBoutiqueOffices/NetOS-coding-standards.git",
    "directory": "packages/eslint-plugin"
  },
  "license": "MIT",
  "author": {
    "name": "Thimon Wentink",
    "email": "thimon.wentink@net-os.com",
    "url": "https://github.com/thimonwentink"
  },
  "type": "module",
  "types": "dist/index.d.mts",
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint src tests types",
    "lint:fix": "npm run lint -- --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "watch": "tsdown --watch",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test:run && npm run build",
    "preversion": "npm run lint && npm run typecheck",
    "postversion": "git push && git push --tags",
    "version": "git add -A"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "globals": "^17.4.0"
  },
  "peerDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
